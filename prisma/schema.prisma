generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  inboundEmail  String?          @unique  // dirección para recibir emails, ej: ptavares@hyper-nexus.com
  name          String
  password      String
  agentAutonomy Int              @default(50)
  createdAt     DateTime         @default(now())
  items         Item[]
  projects      Project[]
  apiKeys       ApiKey[]
  seguimientos  Seguimiento[]
  entradas      EntradaContexto[]
  recordatorios Recordatorio[]
  memorias      MemoriaProfesional[]
  contactos     Contacto[]
  eventos       Evento[]
}

model Project {
  id          String         @id @default(cuid())
  nombre      String
  descripcion String?
  color       String         @default("#60a5fa")
  contexto    Contexto       @default(TRABAJO)
  estado      ProyectoEstado @default(ACTIVO)
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  items          Item[]
  seguimientos   Seguimiento[]
  createdAt      DateTime       @default(now())
}

model Item {
  id                   String      @id @default(cuid())
  tipo                 TipoItem    @default(IDEA)
  titulo               String
  contenido            String?
  estado               EstadoItem  @default(INBOX)
  prioridad            Prioridad   @default(NONE)
  eisenhowerUrgente    Boolean     @default(false)
  eisenhowerImportante Boolean     @default(false)
  contexto             Contexto    @default(TRABAJO)
  etiquetas            String[]
  fechaLimite          DateTime?
  fechaRecordatorio    DateTime?
  notasAgente          String?
  modificadoPor        String      @default("usuario")
  userId               String
  user                 User        @relation(fields: [userId], references: [id])
  proyectoId           String?
  proyecto             Project?    @relation(fields: [proyectoId], references: [id])
  adjuntos             Adjunto[]
  relaciones           Relacion[]        @relation("ItemOrigen")
  relacionesDe         Relacion[]        @relation("ItemDestino")
  actividad            Actividad[]
  seguimientoItems     SeguimientoItem[]
  entradas             EntradaContexto[]
  recordatorios        Recordatorio[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
}

model Adjunto {
  id        String   @id @default(cuid())
  nombre    String
  url       String
  tipo      String
  tamanio   Int
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Relacion {
  id        String       @id @default(cuid())
  tipo      TipoRelacion
  origenId  String
  origen    Item         @relation("ItemOrigen", fields: [origenId], references: [id], onDelete: Cascade)
  destinoId String
  destino   Item         @relation("ItemDestino", fields: [destinoId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
}

model Actividad {
  id          String   @id @default(cuid())
  descripcion String
  autor       String
  itemId      String
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model AgenteFeed {
  id              String       @id @default(cuid())
  tipo            String
  titulo          String
  descripcion     String
  payload         Json
  estado          String       @default("pendiente")
  prioridad       String?
  itemId          String?
  seguimientoId   String?
  seguimiento     Seguimiento? @relation(fields: [seguimientoId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique
  keyPrefix   String
  permissions String[]  @default(["read", "write", "agent"])
  lastUsedAt  DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
}

enum TipoItem {
  TASK
  NOTE
  LINK
  FILE
  EMAIL
  IDEA
}

enum EstadoItem {
  INBOX
  TODO
  IN_PROGRESS
  WAITING
  DONE
  ARCHIVED
}

enum Prioridad {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Contexto {
  TRABAJO
  PERSONAL
  AMBOS
}

enum ProyectoEstado {
  ACTIVO
  PAUSADO
  COMPLETADO
  ARCHIVADO
}

enum TipoRelacion {
  BLOQUEA
  BLOQUEADO_POR
  RELACIONADO_CON
  HIJO_DE
  PADRE_DE
  REFERENCIA
}

// ─── Seguimientos (Active Tracking / Threads) ───

model Seguimiento {
  id              String              @id @default(cuid())
  titulo          String
  descripcion     String?
  estado          EstadoSeguimiento   @default(ACTIVO)
  contexto        Contexto            @default(TRABAJO)
  prioridad       Prioridad           @default(MEDIUM)
  ultimaActividad DateTime            @default(now())
  proximaRevision DateTime?
  userId          String
  user            User                @relation(fields: [userId], references: [id])
  proyectoId      String?
  proyecto        Project?            @relation(fields: [proyectoId], references: [id])
  items           SeguimientoItem[]
  entradas        EntradaContexto[]
  recordatorios   Recordatorio[]
  feedEntries     AgenteFeed[]
  contactos       ContactoSeguimiento[]
  eventos         Evento[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model SeguimientoItem {
  id            String      @id @default(cuid())
  seguimientoId String
  seguimiento   Seguimiento @relation(fields: [seguimientoId], references: [id], onDelete: Cascade)
  itemId        String
  item          Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([seguimientoId, itemId])
}

model EntradaContexto {
  id            String        @id @default(cuid())
  tipo          TipoEntrada
  titulo        String
  contenido     String
  htmlContent   String?       // contenido HTML original del email
  resumen       String?
  metadatos     Json?
  emailHash     String?       // hash para deduplicación de emails (from+subject+body)
  seguimientoId String?
  seguimiento   Seguimiento?  @relation(fields: [seguimientoId], references: [id], onDelete: SetNull)
  itemId        String?
  item          Item?         @relation(fields: [itemId], references: [id], onDelete: SetNull)
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  createdAt     DateTime      @default(now())

  @@index([userId, emailHash])
}

model Recordatorio {
  id              String            @id @default(cuid())
  mensaje         String
  regla           String
  proximoDisparo  DateTime
  activo          Boolean           @default(true)
  tipoRecurrencia TipoRecurrencia   @default(UNA_VEZ)
  seguimientoId   String?
  seguimiento     Seguimiento?      @relation(fields: [seguimientoId], references: [id], onDelete: Cascade)
  itemId          String?
  item            Item?             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  createdAt       DateTime          @default(now())
}

enum EstadoSeguimiento {
  ACTIVO
  EN_ESPERA
  NECESITA_ATENCION
  COMPLETADO
  ARCHIVADO
}

enum TipoEntrada {
  EMAIL
  NOTAS_REUNION
  CONVERSACION
  DOCUMENTO
  NOTA_LIBRE
}

enum TipoRecurrencia {
  UNA_VEZ
  DIARIO
  CADA_N_DIAS
  SEMANAL
  PERSONALIZADO
}

// ─── Calendario (eventos extraídos de emails/mensajes + manuales) ───

model Evento {
  id            String        @id @default(cuid())
  titulo        String
  descripcion   String?
  fecha         DateTime                  // fecha y hora del evento
  fechaFin      DateTime?                 // hora de fin (opcional)
  todoElDia     Boolean       @default(false)
  contexto      Contexto      @default(TRABAJO)
  origen        String        @default("usuario")  // "usuario" | "agente" | "recordatorio"
  seguimientoId String?
  seguimiento   Seguimiento?  @relation(fields: [seguimientoId], references: [id], onDelete: SetNull)
  entradaId     String?                   // entrada que originó este evento (si fue el agente)
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId, fecha])
}

// ─── Contactos (entidades extraídas de emails, reuniones, etc.) ───

model Contacto {
  id            String              @id @default(cuid())
  nombre        String
  email         String?
  telefono      String?
  empresa       String?
  cargo         String?             // rol/posición en la empresa
  notas         String?             // info adicional extraída (legacy, usar notasContacto)
  confianza     Int                 @default(50)  // 0-100, sube con cada mención
  fuentes       String[]            // IDs de entradas que mencionan este contacto
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  seguimientos  ContactoSeguimiento[]
  notasContacto NotaContacto[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([userId, nombre, empresa])
  @@index([userId])
}

// Notas progresivas sobre un contacto — acumuladas por Nexus o el usuario
model NotaContacto {
  id          String   @id @default(cuid())
  contenido   String             // texto de la nota
  autor       String   @default("agente")  // "agente" o "usuario"
  entradaId   String?            // entrada de contexto que originó esta nota (si fue el agente)
  contactoId  String
  contacto    Contacto @relation(fields: [contactoId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contactoId])
}

model ContactoSeguimiento {
  id            String      @id @default(cuid())
  contactoId    String
  contacto      Contacto    @relation(fields: [contactoId], references: [id], onDelete: Cascade)
  seguimientoId String
  seguimiento   Seguimiento @relation(fields: [seguimientoId], references: [id], onDelete: Cascade)
  rol           String?     // "cliente", "fabricante", "partner", "interno", etc.
  createdAt     DateTime    @default(now())

  @@unique([contactoId, seguimientoId])
}

// ─── Memoria Profesional (Nexus aprende sobre el usuario) ───

model MemoriaProfesional {
  id          String          @id @default(cuid())
  categoria   CategoriaMemoria
  clave       String          // tema/persona/proyecto/hecho identificador
  contenido   String          // el hecho o conocimiento
  confianza   Int             @default(50) // 0-100, sube con cada confirmación
  fuentes     String[]        // IDs de entradas que contribuyeron a este hecho
  ultimaVez   DateTime        @default(now()) // última vez que se confirmó/mencionó
  activo      Boolean         @default(true)
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([userId, categoria, clave])
  @@index([userId, activo])
  @@index([userId, categoria])
}

enum CategoriaMemoria {
  PERSONA        // contactos: nombre, rol, relación, email
  PROYECTO       // proyectos/iniciativas: estado, stakeholders, deadlines
  PROCESO        // procesos recurrentes: cómo se hacen las cosas
  PREFERENCIA    // preferencias del usuario: horarios, estilos, prioridades
  ORGANIZACION   // estructura org: equipos, jerarquía, responsabilidades
  HECHO          // hechos sueltos: decisiones tomadas, acuerdos, contexto general
  TEMA           // temas técnicos/de negocio recurrentes
  FAMILIA        // personas del entorno personal: hijos, pareja, familia, amigos — nombres, edades, colegio, etc.
  HOGAR          // gestiones del hogar: colegio, médicos, actividades extraescolares, proveedores casa
  VIDA_PERSONAL  // hechos/contexto personal: rutinas, salud, hobbies, preferencias, eventos sociales
}
